# LLM Provider (Groq - free, OpenAI-compatible)
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Embeddings: Local (sentence-transformers) — no API key needed!
# Model: all-MiniLM-L6-v2 (384 dims, downloads automatically on first run)

# PostgreSQL
DATABASE_URL=postgresql://fte_user:fte_pass@localhost:5432/fte_crm

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Gmail
GMAIL_CREDENTIALS_PATH=./credentials/gmail-service-account.json
GMAIL_SUPPORT_EMAIL=support@yourcompany.com

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# App
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
